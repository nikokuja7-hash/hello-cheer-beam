  { day: "thu", period: "afternoon", startTime: "14:00", endTime: "16:00" },
  { day: "thu", period: "afternoon", startTime: "16:00", endTime: "18:00" },
  { day: "thu", period: "evening", startTime: "18:00", endTime: "20:00" },
  { day: "thu", period: "evening", startTime: "20:00", endTime: "22:00" },

  { day: "fri", period: "morning", startTime: "08:00", endTime: "10:00" },
