  { day: "wed", period: "afternoon", startTime: "12:00", endTime: "14:00" },
  { day: "wed", period: "afternoon", startTime: "14:00", endTime: "16:00" },
  { day: "wed", period: "afternoon", startTime: "16:00", endTime: "18:00" },
  { day: "wed", period: "evening", startTime: "18:00", endTime: "20:00" },
  { day: "wed", period: "evening", startTime: "20:00", endTime: "22:00" },

  { day: "thu", period: "morning", startTime: "08:00", endTime: "10:00" },
  { day: "thu", period: "morning", startTime: "10:00", endTime: "12:00" },
