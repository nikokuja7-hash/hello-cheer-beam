  { day: "mon", period: "evening", startTime: "20:00", endTime: "22:00" },

  { day: "tue", period: "morning", startTime: "08:00", endTime: "10:00" },
  { day: "tue", period: "morning", startTime: "10:00", endTime: "12:00" },
  { day: "tue", period: "afternoon", startTime: "12:00", endTime: "14:00" },
  { day: "tue", period: "afternoon", startTime: "14:00", endTime: "16:00" },
